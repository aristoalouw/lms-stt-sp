{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "type": "pwa-node",
            "request": "launch",
            "name": "Launch LMS Server",
            "program": "${workspaceFolder}/server.js",
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal",
            "env": {
                "PORT": "3000"
            }
        },
        {
            "type": "editor-browser",
            "request": "launch",
            "name": "Open LMS in Integrated Browser",
            "url": "http://localhost:3000",
            "webRoot": "${workspaceFolder}"
        }
    ],
    "compounds": [
        {
            "name": "Launch Server and Open Browser",
            "configurations": [
                "Launch LMS Server",
                "Open LMS in Integrated Browser"
            ]
        }
    ]
}