PORT=3000
NODE_ENV=production

# Pilih salah satu database.
# Untuk Hostinger cPanel, gunakan MySQL:
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_DATABASE=
MYSQL_USER=
MYSQL_PASSWORD=

# Atau untuk MongoDB Atlas/Render:
MONGO_URI=
SESSION_SECRET=

# Dipakai hanya saat database masih kosong dan seed awal dibuat.
# Setelah akun dibuat, password tersimpan sebagai hash di MongoDB.
INITIAL_ADMIN_PASSWORD=
INITIAL_USER_PASSWORD=
